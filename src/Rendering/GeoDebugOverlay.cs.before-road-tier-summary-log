    internal static class GeoDebugOverlay
    {
        private const string RootName = "CityTimelineMod_GroundOverlay";

        internal static void Install(List<List<GeoPoint>> lines, GeoOverlayConfig config)
        {
            Install(lines, new List<List<GeoPoint>>(), new List<List<GeoPoint>>(), config);
        }

        internal static void Install(
            List<List<GeoPoint>> waterLines,
            List<List<GeoPoint>> roadLines,
            GeoOverlayConfig config
        )
        {
            Install(waterLines, new List<List<GeoPoint>>(), roadLines, config);
        }

        internal static void Install(
            List<List<GeoPoint>> waterLines,
            List<List<GeoPoint>> waterAreaOutlines,
            List<List<GeoPoint>> roadLines,
            GeoOverlayConfig config
        )
        {
            Install(waterLines, waterAreaOutlines, ConvertRoadLines(roadLines), config);
        }

        internal static void Install(
            List<List<GeoPoint>> waterLines,
            List<List<GeoPoint>> waterAreaOutlines,
            List<GeoRoadLine> roadLines,
            GeoOverlayConfig config
        )
        {
            var existing = GameObject.Find(RootName);
            if (existing != null)
                UnityEngine.Object.Destroy(existing);

            var root = new GameObject(RootName);
            UnityEngine.Object.DontDestroyOnLoad(root);

            var overlay = root.AddComponent<GroundOverlayBehaviour>();
            overlay.Setup(waterLines, waterAreaOutlines, roadLines, config);

            Log.Info("GroundOverlay: installed HARD visible segment overlay.");
        }

        internal static List<GeoRoadLine> ConvertRoadLines(List<List<GeoPoint>> lines)
        {
            var result = new List<GeoRoadLine>();

            if (lines == null)
                return result;

            foreach (var line in lines)
            {
                if (line != null && line.Count >= 2)
                    result.Add(new GeoRoadLine(line, null, null));
            }

            return result;
        }
    }

    internal sealed class GroundOverlayBehaviour : MonoBehaviour
    {
        private enum CalibrationMode
        {
            Global,
            Water,
            Roads,
            Render
        }

        private List<List<GeoPoint>> _waterLines;
        private List<List<GeoPoint>> _waterAreaOutlines;
        private List<GeoRoadLine> _roadLines;
        private GeoOverlayConfig _config;
        private GeoBounds _bounds;
        private bool _created;
        private CalibrationMode _activeCalibrationMode = CalibrationMode.Global;

        private int _debugWaterSegmentLogs;
        private int _debugRoadSegmentLogs;
        private Vector3 _liveCalibrationOffset = Vector3.zero;
        private float _liveCalibrationRotationDegrees = 0f;
        private float _liveCalibrationScaleX = 1f;
        private float _liveCalibrationScaleZ = 1f;

        internal void Setup(
            List<List<GeoPoint>> waterLines,
            List<List<GeoPoint>> roadLines,
            GeoOverlayConfig config
        )
        {
            Setup(waterLines, new List<List<GeoPoint>>(), GeoDebugOverlay.ConvertRoadLines(roadLines), config);
        }

        internal void Setup(
            List<List<GeoPoint>> waterLines,
            List<List<GeoPoint>> waterAreaOutlines,
            List<List<GeoPoint>> roadLines,
            GeoOverlayConfig config
        )
        {
            Setup(waterLines, waterAreaOutlines, GeoDebugOverlay.ConvertRoadLines(roadLines), config);
        }

        internal void Setup(
            List<List<GeoPoint>> waterLines,
            List<List<GeoPoint>> waterAreaOutlines,
            List<GeoRoadLine> roadLines,
            GeoOverlayConfig config
        )
        {
            _waterLines = waterLines ?? new List<List<GeoPoint>>();
            _waterAreaOutlines = waterAreaOutlines ?? new List<List<GeoPoint>>();
            _roadLines = roadLines ?? new List<GeoRoadLine>();
            _config = config;

            // Important :
            // on garde les bounds de l'eau comme référence,
            // sinon les routes déplaceraient le centre/origine validé.
            var boundsSource = new List<List<GeoPoint>>();
            boundsSource.AddRange(_waterLines);
            boundsSource.AddRange(_waterAreaOutlines);
            _bounds = CalculateBounds(boundsSource);
        }

        private void Update()
        {
            if (!_created)
            {
                _created = true;
                CreateOverlay();
                return;
            }

            HandleCalibrationInput();
        }

        private void CreateOverlay()
        {
            if (_waterLines == null || _waterLines.Count == 0)
            {
                Log.Info("GroundOverlay: no water geometry.");
                return;
            }

            var originLon = _config.UseGeoJsonCenter ? _bounds.CenterLon : _config.OriginLon;
            var originLat = _config.UseGeoJsonCenter ? _bounds.CenterLat : _config.OriginLat;

            Log.Info("GroundOverlay: creating HARD visible segment overlay.");
            Log.Info("GroundOverlay: bounds lon=[" + _bounds.MinLon + ", " + _bounds.MaxLon + "], lat=[" + _bounds.MinLat + ", " + _bounds.MaxLat + "]");
            Log.Info("GroundOverlay: center lon=" + _bounds.CenterLon + ", lat=" + _bounds.CenterLat);
            Log.Info("GroundOverlay: origin lon=" + originLon + ", lat=" + originLat);
            Log.Info("GroundOverlay: world origin x=" + _config.WorldOriginX + ", z=" + _config.WorldOriginZ);
            Log.Info("GroundOverlay: worldScale=" + _config.WorldScale + ", groundMargin=" + _config.GroundMargin);

            Log.Info(
                "GroundOverlay: overlayRotationDegrees=" + _config.OverlayRotationDegrees +
                ", overlayScaleX=" + _config.OverlayScaleX +
                ", overlayScaleZ=" + _config.OverlayScaleZ +
                ", flipX=" + _config.FlipX +
                ", flipZ=" + _config.FlipZ
            );

            Log.Info("GroundOverlay: water segmentWidth=" + _config.SegmentWidth + ", segmentHeight=" + _config.SegmentHeight);
            Log.Info("GroundOverlay: waterLineSegmentWidth=" + _config.WaterLineSegmentWidth + ", waterLineSegmentHeight=" + _config.WaterLineSegmentHeight);
            Log.Info("GroundOverlay: waterAreaSegmentWidth=" + _config.WaterAreaSegmentWidth + ", waterAreaSegmentHeight=" + _config.WaterAreaSegmentHeight);
            Log.Info(
                "GroundOverlay: renderWaterAreaOutlines=" + _config.RenderWaterAreaOutlines +
                ", renderWaterAreaFillMeshes=" + _config.RenderWaterAreaFillMeshes +
                ", maxWaterAreaFillMeshesDebug=" + _config.MaxWaterAreaFillMeshesDebug +
                ", waterAreaFillYOffset=" + _config.WaterAreaFillYOffset
            );
            Log.Info("GroundOverlay: maxRenderedSegments=" + _config.MaxRenderedSegments + ", maxWaterSegmentsDebug=" + _config.MaxWaterSegmentsDebug + ", pointStride=" + _config.PointStride);
            Log.Info(
                "GroundOverlay: roadSegmentWidth=" + _config.RoadSegmentWidth +
                ", roadSegmentHeight=" + _config.RoadSegmentHeight +
                ", maxRoadSegmentsDebug=" + _config.MaxRoadSegmentsDebug
            );
            Log.Info("GroundOverlay: road hierarchy style=highway");
            Log.Info("GroundOverlay: minimumRoadDebugTier=" + _config.MinimumRoadDebugTier);

            var cyan = CreateMaterial(Color.cyan);
            var waterAreaBlue = CreateMaterial(new Color(0.05f, 0.45f, 1f));
            var waterAreaFillBlue = CreateMaterial(new Color(0.02f, 0.18f, 0.55f, 0.65f));
            var orange = CreateMaterial(new Color(1f, 0.45f, 0f));
            var roadMotorwayMaterial = CreateMaterial(new Color(1f, 0.18f, 0f));
            var roadPrimaryMaterial = CreateMaterial(new Color(1f, 0.38f, 0f));
            var roadSecondaryMaterial = CreateMaterial(new Color(1f, 0.62f, 0.05f));
            var roadTertiaryMaterial = CreateMaterial(new Color(1f, 0.82f, 0.15f));
            var roadLinkMaterial = CreateMaterial(new Color(1f, 0.28f, 0f));
            var red = CreateMaterial(Color.red);
            var green = CreateMaterial(Color.green);
            var yellow = CreateMaterial(Color.yellow);
            var magenta = CreateMaterial(Color.magenta);

            var stride = Math.Max(1, _config.PointStride);

            var createdWaterSegments = 0;
            var createdWaterLines = 0;

            Vector3 firstWorld = Vector3.zero;
            Vector3 lastWorld = Vector3.zero;
            var hasEndpoints = false;

            // ==========================================================
            // EAU : lignes et contours de surfaces rendus séparément
            // ==========================================================
            RenderWaterOverlayGroups(
                cyan,
                waterAreaBlue,
                waterAreaFillBlue,
                stride,
                ref createdWaterSegments,
                ref createdWaterLines,
                ref firstWorld,
                ref lastWorld,
                ref hasEndpoints
            );

            var createdRoadLines = 0;
            var createdRoadSegments = RenderRoadGroup(
                roadMotorwayMaterial,
                roadPrimaryMaterial,
                roadSecondaryMaterial,
                roadTertiaryMaterial,
                roadLinkMaterial,
                orange,
                stride,
                originLon,
                originLat,
                ref createdRoadLines
            );

            var center = new Vector3(
                _config.WorldOriginX,
                ResolveY(new Vector3(_config.WorldOriginX, 0f, _config.WorldOriginZ)) + _config.GroundMargin,
                _config.WorldOriginZ
            );

            if (_config.DebugBeacons)
            {
                CreateBeacon("ground_red_center_beacon", center, red);

                if (hasEndpoints)
                {
                    CreateBeacon("ground_green_first_beacon", firstWorld, green);
                    CreateBeacon("ground_yellow_last_beacon", lastWorld, yellow);
                }
            }

            if (_config.DebugTower)
                CreateTower("ground_magenta_debug_tower", center, magenta);

            Log.Info("GroundOverlay: first world point=" + firstWorld);
            Log.Info("GroundOverlay: last world point=" + lastWorld);
            Log.Info("GroundOverlay: center world point=" + center);

            Log.Info(
                "GroundOverlay: created water lines=" + createdWaterLines +
                ", water cube segments=" + createdWaterSegments +
                ", road lines=" + createdRoadLines +
                ", road cube segments=" + createdRoadSegments
            );

            LogRoadHighwaySummary();
        }



        private int RenderRoadGroup(
            Material roadMotorwayMaterial,
            Material roadPrimaryMaterial,
            Material roadSecondaryMaterial,
            Material roadTertiaryMaterial,
            Material roadLinkMaterial,
            Material fallbackRoadMaterial,
            int stride,
            double originLon,
            double originLat,
            ref int createdRoadLines
        )
        {
            var createdRoadSegments = 0;

            if (!_config.RenderRoads || _roadLines == null || _roadLines.Count == 0)
                return createdRoadSegments;

            foreach (var roadLine in _roadLines)
            {
                var road = roadLine != null ? roadLine.Points : null;

                if (road == null || road.Count < 2)
                    continue;

                var highway = roadLine != null ? roadLine.Highway : null;

                if (!ShouldRenderRoadByTier(highway, _config.MinimumRoadDebugTier))
                    continue;

                var roadMaterial = ResolveRoadMaterial(
                    highway,
                    roadMotorwayMaterial,
                    roadPrimaryMaterial,
                    roadSecondaryMaterial,
                    roadTertiaryMaterial,
                    roadLinkMaterial,
                    fallbackRoadMaterial
                );
                var roadWidth = ResolveRoadWidth(highway, _config.RoadSegmentWidth);
                var roadNamePrefix = ResolveRoadNamePrefix(highway);

                createdRoadLines++;

                for (var i = 0; i < road.Count - stride; i += stride)
                {
                    if (createdRoadSegments >= _config.MaxRoadSegmentsDebug)
                        break;

                    var a = GeoTransform.ToWorld(road[i], _config, originLon, originLat);
                    var b = GeoTransform.ToWorld(
                        road[Math.Min(i + stride, road.Count - 1)],
                        _config,
                        originLon,
                        originLat
                    );

                    a.y = ResolveY(a) + _config.GroundMargin;
                    b.y = ResolveY(b) + _config.GroundMargin;

                    if (CreateOrientedRoadCube(
                        roadNamePrefix + createdRoadSegments,
                        a,
                        b,
                        roadMaterial,
                        roadWidth,
                        _config.RoadSegmentHeight
                    ))
                    {
                        createdRoadSegments++;
                    }
                }

                if (createdRoadSegments >= _config.MaxRoadSegmentsDebug)
                    break;
            }

            return createdRoadSegments;
        }



        private static bool ShouldRenderRoadByTier(string highway, int minimumTier)
        {
            if (minimumTier <= 0)
                return true;

            return ResolveRoadTier(highway) >= minimumTier;
        }

        private static int ResolveRoadTier(string highway)
        {
            if (string.IsNullOrWhiteSpace(highway))
                return 0;

            var value = highway.ToLowerInvariant();

            if (value.EndsWith("_link", StringComparison.OrdinalIgnoreCase))
                value = value.Substring(0, value.Length - "_link".Length);

            switch (value)
            {
                case "motorway":
                case "trunk":
                    return 4;

                case "primary":
                    return 3;

                case "secondary":
                    return 2;

                case "tertiary":
                    return 1;

                default:
                    return 0;
            }
        }


        private static Material ResolveRoadMaterial(
            string highway,
            Material motorwayMaterial,
            Material primaryMaterial,
            Material secondaryMaterial,
            Material tertiaryMaterial,
            Material linkMaterial,
            Material fallbackMaterial
        )
        {
            if (string.IsNullOrWhiteSpace(highway))
                return fallbackMaterial;

            var value = highway.ToLowerInvariant();

            if (value.EndsWith("_link", StringComparison.OrdinalIgnoreCase))
                return linkMaterial;

            switch (value)
            {
                case "motorway":
                case "trunk":
                    return motorwayMaterial;

                case "primary":
                    return primaryMaterial;

                case "secondary":
                    return secondaryMaterial;

                case "tertiary":
                    return tertiaryMaterial;

                default:
                    return fallbackMaterial;
            }
        }

        private static float ResolveRoadWidth(string highway, float baseWidth)
        {
            var width = Mathf.Max(1f, baseWidth);

            if (string.IsNullOrWhiteSpace(highway))
                return width;

            var value = highway.ToLowerInvariant();

            if (value.EndsWith("_link", StringComparison.OrdinalIgnoreCase))
                return Mathf.Max(1f, width * 0.55f);

            switch (value)
            {
                case "motorway":
                    return Mathf.Max(1f, width * 1.45f);

                case "trunk":
                    return Mathf.Max(1f, width * 1.35f);

                case "primary":
                    return Mathf.Max(1f, width * 1.15f);

                case "secondary":
                    return Mathf.Max(1f, width * 0.85f);

                case "tertiary":
                    return Mathf.Max(1f, width * 0.65f);

                default:
                    return Mathf.Max(1f, width * 0.75f);
            }
        }

        private static string ResolveRoadNamePrefix(string highway)
        {
            if (string.IsNullOrWhiteSpace(highway))
                return "orange_road_unknown_segment_";

            var value = highway
                .ToLowerInvariant()
                .Replace(" ", "_")
                .Replace("-", "_");

            return "orange_road_" + value + "_segment_";
        }


        private void LogRoadHighwaySummary()
        {
            if (_roadLines == null || _roadLines.Count == 0)
                return;

            var counts = new Dictionary<string, int>();

            foreach (var road in _roadLines)
            {
                var highway = road != null ? road.Highway : null;

                if (string.IsNullOrWhiteSpace(highway))
                    highway = "(missing)";

                int count;
                counts.TryGetValue(highway, out count);
                counts[highway] = count + 1;
            }

            var parts = new List<string>();

            foreach (var pair in counts)
                parts.Add(pair.Key + "=" + pair.Value);

            Log.Info("GroundOverlay: road highway summary: " + string.Join(", ", parts.ToArray()));
        }


        private void RenderWaterOverlayGroups(
            Material waterLineMaterial,
            Material waterAreaOutlineMaterial,
            Material waterAreaFillMaterial,
            int stride,
            ref int createdWaterSegments,
            ref int createdWaterLines,
            ref Vector3 firstWorld,
            ref Vector3 lastWorld,
            ref bool hasEndpoints
        )
        {
            RenderWaterGroup(
                _waterLines,
                "cyan_water_line_segment_",
                waterLineMaterial,
                _config.WaterLineSegmentWidth,
                _config.WaterLineSegmentHeight,
                stride,
                ref createdWaterSegments,
                ref createdWaterLines,
                ref firstWorld,
                ref lastWorld,
                ref hasEndpoints
            );

            if (_config.RenderWaterAreas && _config.RenderWaterAreaFillMeshes)
                RenderWaterAreaFillMeshes(_waterAreaOutlines, waterAreaFillMaterial, stride);

            if (_config.RenderWaterAreas && _config.RenderWaterAreaOutlines)
            {
                RenderWaterGroup(
                    _waterAreaOutlines,
                    "blue_water_area_segment_",
                    waterAreaOutlineMaterial,
                    _config.WaterAreaSegmentWidth,
                    _config.WaterAreaSegmentHeight,
                    stride,
                    ref createdWaterSegments,
                    ref createdWaterLines,
                    ref firstWorld,
                    ref lastWorld,
                    ref hasEndpoints
                );
            }
        }


        private void RenderWaterGroup(
            List<List<GeoPoint>> lines,
            string namePrefix,
            Material material,
            float segmentWidth,
            float segmentHeight,
            int stride,
            ref int createdWaterSegments,
            ref int createdWaterLines,
            ref Vector3 firstWorld,
            ref Vector3 lastWorld,
            ref bool hasEndpoints
        )
        {
            if (lines == null || lines.Count == 0)
                return;

            var originLon = _config.UseGeoJsonCenter ? _bounds.CenterLon : _config.OriginLon;
            var originLat = _config.UseGeoJsonCenter ? _bounds.CenterLat : _config.OriginLat;

            foreach (var line in lines)
            {
                if (line == null || line.Count < 2)
                    continue;

                createdWaterLines++;

                for (var i = 0; i < line.Count - stride; i += stride)
                {
                    if (createdWaterSegments >= _config.MaxWaterSegmentsDebug)
                        break;

                    var a = GeoTransform.ToWorld(line[i], _config, originLon, originLat);
                    var b = GeoTransform.ToWorld(line[Math.Min(i + stride, line.Count - 1)], _config, originLon, originLat);

                    a.y = ResolveY(a) + _config.GroundMargin;
                    b.y = ResolveY(b) + _config.GroundMargin;

                    if (!hasEndpoints)
                    {
                        firstWorld = a;
                        hasEndpoints = true;
                    }

                    lastWorld = b;

                    if (CreateOrientedWaterCube(
                        namePrefix + createdWaterSegments,
                        a,
                        b,
                        material,
                        segmentWidth,
                        segmentHeight
                    ))
                    {
                        createdWaterSegments++;
                    }
                }

                if (createdWaterSegments >= _config.MaxWaterSegmentsDebug)
                    break;
            }
        }


        private int RenderWaterAreaFillMeshes(
            List<List<GeoPoint>> outlines,
            Material material,
            int stride
        )
        {
            if (outlines == null || outlines.Count == 0)
                return 0;

            var originLon = _config.UseGeoJsonCenter ? _bounds.CenterLon : _config.OriginLon;
            var originLat = _config.UseGeoJsonCenter ? _bounds.CenterLat : _config.OriginLat;

            var createdMeshes = 0;
            var maxFillMeshesDebug = Math.Max(1, _config.MaxWaterAreaFillMeshesDebug);
            const int maxVerticesPerMesh = 60000;

            foreach (var outline in outlines)
            {
                if (createdMeshes >= maxFillMeshesDebug)
                    break;

                if (outline == null || outline.Count < 3)
                    continue;

                var vertices = new List<Vector3>();

                for (var i = 0; i < outline.Count; i += stride)
                {
                    var world = GeoTransform.ToWorld(outline[i], _config, originLon, originLat);
                    world.y = ResolveY(world) + _config.GroundMargin + _config.WaterAreaFillYOffset;
                    vertices.Add(world);
                }

                if (vertices.Count >= 2)
                {
                    var first = vertices[0];
                    var last = vertices[vertices.Count - 1];

                    if (Vector3.Distance(first, last) < 0.1f)
                        vertices.RemoveAt(vertices.Count - 1);
                }

                if (vertices.Count < 3)
                    continue;

                if (vertices.Count > maxVerticesPerMesh)
                {
                    Log.Info(
                        "GroundOverlay: skipped water area fill mesh with too many vertices: " +
                        vertices.Count
                    );
                    continue;
                }

                var triangles = new List<int>((vertices.Count - 2) * 3);

                var signedArea = 0.0;
                for (var i = 0; i < vertices.Count; i++)
                {
                    var a = vertices[i];
                    var b = vertices[(i + 1) % vertices.Count];
                    signedArea += (double)a.x * b.z - (double)b.x * a.z;
                }

                for (var i = 1; i < vertices.Count - 1; i++)
                {
                    if (signedArea >= 0.0)
                    {
                        triangles.Add(0);
                        triangles.Add(i + 1);
                        triangles.Add(i);
                    }
                    else
                    {
                        triangles.Add(0);
                        triangles.Add(i);
                        triangles.Add(i + 1);
                    }
                }

                var mesh = new Mesh();
                mesh.name = "water_area_fill_mesh_data_" + createdMeshes;
                mesh.vertices = vertices.ToArray();
                mesh.triangles = triangles.ToArray();
                mesh.RecalculateBounds();
                mesh.RecalculateNormals();

                var obj = new GameObject("blue_water_area_fill_mesh_" + createdMeshes);
                obj.transform.SetParent(transform, true);
                obj.transform.position = Vector3.zero;
                obj.transform.rotation = Quaternion.identity;
                obj.transform.localScale = Vector3.one;

                var filter = obj.AddComponent<MeshFilter>();
                filter.mesh = mesh;

                var renderer = obj.AddComponent<MeshRenderer>();
                renderer.material = material;

                createdMeshes++;
            }

            Log.Info("GroundOverlay: created water area fill meshes=" + createdMeshes);
            return createdMeshes;
        }


        private void HandleCalibrationInput()
        {
            if (_config == null || !_config.EnableCalibrationControls)
                return;

            if (Input.GetKeyDown(KeyCode.F6))
            {
                CycleCalibrationMode();
                return;
            }

            if (Input.GetKeyDown(KeyCode.F7))
            {
                LogCalibrationState();
                return;
            }

            if (Input.GetKeyDown(KeyCode.F8))
            {
                RebuildOverlayPreservingLiveTransform();
                return;
            }

            // Sauvegarde + bake dans config.json
            if (Input.GetKeyDown(KeyCode.F9))
            {
                SaveAndBakeLiveCalibration();
                return;
            }

            if (_activeCalibrationMode != CalibrationMode.Global)
                return;

            var changed = false;

            var multiplier = 1f;

            if (Input.GetKey(KeyCode.LeftShift) || Input.GetKey(KeyCode.RightShift))
                multiplier *= 10f;

            if (Input.GetKey(KeyCode.LeftControl) || Input.GetKey(KeyCode.RightControl))
                multiplier *= 0.1f;

            var moveStep = _config.CalibrationMoveStep * multiplier;
            var rotationStep = _config.CalibrationRotationStep * multiplier;
            var scaleStep = _config.CalibrationScaleStep * multiplier;

            // Déplacement X/Z
            if (Input.GetKeyDown(KeyCode.Keypad8))
            {
                _liveCalibrationOffset.z += moveStep;
                changed = true;
            }

            if (Input.GetKeyDown(KeyCode.Keypad2))
            {
                _liveCalibrationOffset.z -= moveStep;
                changed = true;
            }

            if (Input.GetKeyDown(KeyCode.Keypad6))
            {
                _liveCalibrationOffset.x += moveStep;
                changed = true;
            }

            if (Input.GetKeyDown(KeyCode.Keypad4))
            {
                _liveCalibrationOffset.x -= moveStep;
                changed = true;
            }

            // Rotation
            if (Input.GetKeyDown(KeyCode.Keypad7))
            {
                _liveCalibrationRotationDegrees -= rotationStep;
                changed = true;
            }

            if (Input.GetKeyDown(KeyCode.Keypad9))
            {
                _liveCalibrationRotationDegrees += rotationStep;
                changed = true;
            }

            // Scale uniforme
            if (Input.GetKeyDown(KeyCode.Keypad1))
            {
                _liveCalibrationScaleX = Mathf.Max(0.01f, _liveCalibrationScaleX - scaleStep);
                _liveCalibrationScaleZ = Mathf.Max(0.01f, _liveCalibrationScaleZ - scaleStep);
                changed = true;
            }

            if (Input.GetKeyDown(KeyCode.Keypad3))
            {
                _liveCalibrationScaleX += scaleStep;
                _liveCalibrationScaleZ += scaleStep;
                changed = true;
            }

            // Scale X
            if (Input.GetKeyDown(KeyCode.KeypadDivide))
            {
                _liveCalibrationScaleX = Mathf.Max(0.01f, _liveCalibrationScaleX - scaleStep);
                changed = true;
            }

            if (Input.GetKeyDown(KeyCode.KeypadMultiply))
            {
                _liveCalibrationScaleX += scaleStep;
                changed = true;
            }

            // Scale Z
            if (Input.GetKeyDown(KeyCode.KeypadMinus))
            {
                _liveCalibrationScaleZ = Mathf.Max(0.01f, _liveCalibrationScaleZ - scaleStep);
                changed = true;
            }

            if (Input.GetKeyDown(KeyCode.KeypadPlus))
            {
                _liveCalibrationScaleZ += scaleStep;
                changed = true;
            }

            // Reset live seulement
            if (Input.GetKeyDown(KeyCode.Keypad5))
            {
                _liveCalibrationOffset = Vector3.zero;
                _liveCalibrationRotationDegrees = 0f;
                _liveCalibrationScaleX = 1f;
                _liveCalibrationScaleZ = 1f;
                changed = true;

                Log.Info("GroundOverlay calibration: live reset.");
            }

            if (changed)
            {
                ApplyLiveCalibrationTransform();
                LogLiveCalibrationState();
            }
        }

        private void CycleCalibrationMode()
        {
            if (_activeCalibrationMode == CalibrationMode.Render)
                _activeCalibrationMode = CalibrationMode.Global;
            else
                _activeCalibrationMode = (CalibrationMode)((int)_activeCalibrationMode + 1);

            Log.Info("GroundOverlay calibration: active mode=" + GetCalibrationModeLabel(_activeCalibrationMode));
        }

        private void RebuildOverlayPreservingLiveTransform()
        {
            var livePosition = transform.position;
            var liveRotation = transform.rotation;
            var liveScale = transform.localScale;

            transform.position = Vector3.zero;
            transform.rotation = Quaternion.identity;
            transform.localScale = Vector3.one;

            ClearOverlayChildren();
            CreateOverlay();

            transform.position = livePosition;
            transform.rotation = liveRotation;
            transform.localScale = liveScale;

            Log.Info("GroundOverlay calibration: overlay rebuilt. mode=" + GetCalibrationModeLabel(_activeCalibrationMode));
        }

        private void ApplyLiveCalibrationTransform()
        {
            transform.position = new Vector3(
                _liveCalibrationOffset.x,
                0f,
                _liveCalibrationOffset.z
            );

            transform.rotation = Quaternion.Euler(
                0f,
                _liveCalibrationRotationDegrees,
                0f
            );

            transform.localScale = new Vector3(
                _liveCalibrationScaleX,
                1f,
                _liveCalibrationScaleZ
            );
        }

